#!/usr/bin/env bash
source "$HOME/.config/theme/colors.sh"

bg() { printf '\033[48;2;%d;%d;%dm' "0x${1:1:2}" "0x${1:3:2}" "0x${1:5:2}"; }
fg() { printf '\033[38;2;%d;%d;%dm' "0x${1:1:2}" "0x${1:3:2}" "0x${1:5:2}"; }
RST=$'\033[0m'
SEL=$(fg "$THEME_FG_BRIGHT")$(bg "$THEME_SELECTION")

LINES=(
  "  tmux keybindings"
  ""
  "  PREFIX = Ctrl-A"
  ""
  "  windows"
  "  c         new window"
  "  &         kill window"
  "  n / p     next / prev window"
  "  0-9       jump to window"
  "  ,         rename window"
  "  w         window tree"
  "  f         find window"
  "  <         window menu (swap/kill/rename)"
  ""
  "  panes"
  "  |         split vertical"
  "  -         split horizontal"
  "  h j k l   navigate panes"
  "  H J K L   resize panes"
  "  x         kill pane"
  "  z         toggle zoom"
  "  >         pane menu (split/swap/kill/zoom)"
  ""
  "  session"
  "  :new      new session"
  "  S         pick session"
  "  d         detach"
  "  s         session tree"
  "  D         choose client (detach others)"
  "  \$         rename session"
  ""
  "  other"
  "  W         pick window"
  "  [         copy mode (vi)"
  "  =         paste buffers"
  "  /         describe key binding"
  "  ?         this help"
  ""
  "  j/k scroll · {/} section · g/G top/bottom"
  "  q/Esc close"
)

TOTAL=${#LINES[@]}
CURSOR=0
OFFSET=0
TERM_W=$(tput cols)
TERM_H=$(tput lines)

printf '\033[?1049h\033[?25l'
trap 'printf "\033[?25h\033[?1049l"' EXIT

scroll_into_view() {
  if (( CURSOR < OFFSET )); then
    OFFSET=$CURSOR
  elif (( CURSOR >= OFFSET + TERM_H )); then
    OFFSET=$((CURSOR - TERM_H + 1))
  fi
  (( OFFSET < 0 )) && OFFSET=0
  local max=$((TOTAL - TERM_H))
  (( max < 0 )) && max=0
  (( OFFSET > max )) && OFFSET=$max
}

render_line() {
  local idx=$1
  if (( idx < TOTAL )); then
    if (( idx == CURSOR )); then
      printf '%b%-*s%b' "$SEL" "$TERM_W" "${LINES[idx]}" "$RST"
    else
      printf '%-*s' "$TERM_W" "${LINES[idx]}"
    fi
  else
    printf '%-*s' "$TERM_W" ""
  fi
}

draw_full() {
  local buf=$'\033[H'
  for (( row=0; row < TERM_H; row++ )); do
    local idx=$((OFFSET + row))
    if (( idx < TOTAL )); then
      if (( idx == CURSOR )); then
        printf -v line '%b%-*s%b' "$SEL" "$TERM_W" "${LINES[idx]}" "$RST"
      else
        printf -v line '%-*s' "$TERM_W" "${LINES[idx]}"
      fi
    else
      printf -v line '%-*s' "$TERM_W" ""
    fi
    if (( row < TERM_H - 1 )); then
      buf+="${line}"$'\n'
    else
      buf+="${line}"
    fi
  done
  printf '%s' "$buf"
}

draw_line() {
  local idx=$1
  local row=$((idx - OFFSET))
  if (( row < 0 || row >= TERM_H )); then
    return
  fi
  printf '\033[%d;1H' "$((row + 1))"
  render_line "$idx"
}

update() {
  local prev=$1
  local prev_off=$2
  if (( OFFSET != prev_off )); then
    draw_full
  else
    draw_line "$prev"
    draw_line "$CURSOR"
  fi
}

ESC=$(printf '\x1b')
draw_full
while true; do
  IFS= read -rsn1 key
  case "$key" in
    "$ESC") break ;;
    q) break ;;
    j)
      if (( CURSOR < TOTAL - 1 )); then
        prev=$CURSOR prev_off=$OFFSET
        (( CURSOR++ ))
        scroll_into_view
        update "$prev" "$prev_off"
      fi
      ;;
    k)
      if (( CURSOR > 0 )); then
        prev=$CURSOR prev_off=$OFFSET
        (( CURSOR-- ))
        scroll_into_view
        update "$prev" "$prev_off"
      fi
      ;;
    G)
      prev=$CURSOR prev_off=$OFFSET
      CURSOR=$((TOTAL - 1))
      scroll_into_view
      update "$prev" "$prev_off"
      ;;
    g)
      prev=$CURSOR prev_off=$OFFSET
      CURSOR=0
      scroll_into_view
      update "$prev" "$prev_off"
      ;;
    "}")
      prev=$CURSOR prev_off=$OFFSET
      for (( i=CURSOR+1; i<TOTAL; i++ )); do
        if [[ -z "${LINES[i]}" ]]; then
          CURSOR=$i
          break
        fi
      done
      scroll_into_view
      update "$prev" "$prev_off"
      ;;
    "{")
      prev=$CURSOR prev_off=$OFFSET
      for (( i=CURSOR-1; i>=0; i-- )); do
        if [[ -z "${LINES[i]}" ]]; then
          CURSOR=$i
          break
        fi
      done
      scroll_into_view
      update "$prev" "$prev_off"
      ;;
  esac
done

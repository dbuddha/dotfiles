#!/usr/bin/env bash
eval "$(tmux show-environment -g 2>/dev/null | grep '^THEME_')"
FG_ACTIVE=$THEME_SESSION_ACCENT
FG_INACTIVE=$THEME_COMMENT
BG_ACTIVE=$THEME_CURSORLINE
BG_INACTIVE=$THEME_BORDER
FG_OVERFLOW=$THEME_MUTED

sessions=()
attached=()
while IFS=: read -r name is_attached; do
  sessions+=("$name")
  attached+=("$is_attached")
done < <(tmux list-sessions -F '#{session_name}:#{?session_attached,1,0}')
total=${#sessions[@]}
if (( total == 0 )); then
  exit 0
fi
active_idx=0
for (( i=0; i<total; i++ )); do
  if [[ "${attached[i]}" == "1" ]]; then
    active_idx=$i
    break
  fi
done
max_visible=4
if (( total <= max_visible )); then
  start=0
  end=$total
else
  start=$((active_idx - max_visible / 2))
  (( start < 0 )) && start=0
  end=$((start + max_visible))
  if (( end > total )); then
    end=$total
    start=$((end - max_visible))
  fi
fi
ICON=$''
output="#[fg=${FG_ACTIVE},bg=${BG_ACTIVE},bold] ${ICON} #[bg=default,nobold]"
for (( i=start; i<end; i++ )); do
  s="${sessions[i]}"
  if [[ "${attached[i]}" == "1" ]]; then
    output+="#[fg=${FG_ACTIVE},bg=${BG_ACTIVE},bold] ${s} #[bg=default,nobold]"
  else
    output+="#[fg=${FG_INACTIVE},bg=${BG_INACTIVE},nobold] ${s} #[bg=default]"
  fi
done
overflow=$((total - (end - start)))
if (( overflow > 0 )); then
  output+="#[fg=${FG_OVERFLOW},bg=default] +${overflow} "
fi
printf '%s' "$output"

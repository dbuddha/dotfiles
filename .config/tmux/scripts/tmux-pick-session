#!/usr/bin/env bash
source "$HOME/.config/theme/colors.sh"

bg() { printf '\033[48;2;%d;%d;%dm' "0x${1:1:2}" "0x${1:3:2}" "0x${1:5:2}"; }
fg() { printf '\033[38;2;%d;%d;%dm' "0x${1:1:2}" "0x${1:3:2}" "0x${1:5:2}"; }
RST=$'\033[0m'
BOLD=$'\033[1m'

C_TITLE=$(fg "$THEME_GREEN")
C_ARROW=$(fg "$THEME_SESSION_ACCENT")
C_SEL_FG=$(fg "$THEME_FG_BRIGHT")
C_SEL_BG=$(bg "$THEME_SELECTION")
C_ATTACHED=$(fg "$THEME_CYAN")
C_ITEM=$(fg "$THEME_MUTED")
C_HINT=$(fg "$THEME_COMMENT")

ESC=$(printf '\x1b')
current=$(tmux display-message -p '#S')
sessions=()
while IFS= read -r line; do
  sessions+=("$line")
done < <(tmux list-sessions -F '#{session_name}')
total=${#sessions[@]}
if (( total == 0 )); then
  exit 0
fi
cursor=0
for (( i=0; i<total; i++ )); do
  if [[ "${sessions[i]}" == "$current" ]]; then
    cursor=$i
    break
  fi
done

TERM_W=$(tput cols)
TERM_H=$(tput lines)

printf '\033[?1049h\033[?25l'
trap 'printf "\033[?25h\033[?1049l"' EXIT

render_line() {
  local i=$1 tag=""
  [[ "${sessions[i]}" == "$current" ]] && tag=" ${C_ATTACHED}(attached)${RST}"
  if (( i == cursor )); then
    printf -v REPLY '%b%b %b>%b %s %b%b' "$C_SEL_BG" "$C_SEL_FG" "$C_ARROW" "$C_SEL_FG" "${sessions[i]}" "$RST" "$tag"
  else
    printf -v REPLY '    %b%s%b%b' "$C_ITEM" "${sessions[i]}" "$RST" "$tag"
  fi
}

draw_full() {
  local buf=$'\033[H'
  # title + blank line = rows 1-2
  printf -v line '  %b%bsessions%b' "$BOLD" "$C_TITLE" "$RST"
  buf+="${line}"$'\n'
  printf -v line '%-*s' "$TERM_W" ""
  buf+="${line}"$'\n'
  # session items = rows 3..2+total
  for (( i=0; i<total; i++ )); do
    render_line "$i"
    buf+="${REPLY}"$'\n'
  done
  # blank line + hints (2 lines)
  printf -v line '%-*s' "$TERM_W" ""
  buf+="${line}"$'\n'
  printf -v line '  %bj/k move · Enter select%b' "$C_HINT" "$RST"
  buf+="${line}"$'\n'
  printf -v line '  %bq/Esc cancel%b' "$C_HINT" "$RST"
  buf+="${line}"
  # fill remaining rows
  local used=$(( 2 + total + 3 ))
  for (( r=used; r<TERM_H; r++ )); do
    printf -v line '%-*s' "$TERM_W" ""
    buf+=$'\n'"${line}"
  done
  printf '%s' "$buf"
}

draw_line() {
  local i=$1
  local row=$(( i + 3 ))
  printf '\033[%d;1H' "$row"
  render_line "$i"
  printf '%-*s' "$TERM_W" ""
  printf '\033[%d;1H' "$row"
  printf '%s' "$REPLY"
}

update() {
  local prev=$1
  draw_line "$prev"
  draw_line "$cursor"
}

draw_full
while true; do
  IFS= read -rsn1 key
  case "$key" in
    "$ESC") break ;;
    q) break ;;
    j)
      if (( cursor < total - 1 )); then
        prev=$cursor
        (( cursor++ ))
        update "$prev"
      fi
      ;;
    k)
      if (( cursor > 0 )); then
        prev=$cursor
        (( cursor-- ))
        update "$prev"
      fi
      ;;
    "")
      tmux switch-client -t "${sessions[cursor]}"
      break
      ;;
  esac
done
